# ============================================================
# SecureSync — NEXO AI | Environment Variables Template
# ============================================================
# Copy to .env and fill in all values — NEVER commit .env to git.
# The .gitignore covers .env and .env.* explicitly.
#
# Where each variable is read:
#   ⚙  platform API  (app/core/config.py + docker-compose.yml)
#   ⚡  frontend      (Next.js build + runtime)
#   🐳  oss-stack     (Wazuh / Greenbone docker-compose.yml)
# ============================================================

# ── ⚙ Application ────────────────────────────────────────────
ENVIRONMENT=development             # development | staging | production
SECRET_KEY=                         # openssl rand -hex 32  (min 32 chars)
JWT_ALGORITHM=HS256                 # HS256 (dev) | RS256 (production)
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
INVITATION_TTL_DAYS=7
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR

# ── ⚡ Frontend (Next.js) ────────────────────────────────────
NEXTAUTH_SECRET=                    # openssl rand -hex 32
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── ⚙ PostgreSQL ─────────────────────────────────────────────
POSTGRES_DB=securesync
POSTGRES_USER=securesync
POSTGRES_PASSWORD=                  # strong random password
DATABASE_URL=postgresql+psycopg://securesync:PASSWORD@postgres:5432/securesync

# ── ⚙ Redis ──────────────────────────────────────────────────
REDIS_PASSWORD=                     # strong random password
REDIS_URL=redis://:PASSWORD@redis:6379/0

# ── ⚙🐳 Wazuh (Endpoint Agent + SIEM) ─────────────────────────
WAZUH_API_URL=https://wazuh.manager:55000
WAZUH_USERNAME=wazuh-wui
WAZUH_PASSWORD=
WAZUH_VERIFY_SSL=true               # set false ONLY in dev (self-signed certs)
# ── 🐳 oss-stack/wazuh/docker-compose.yml only
WAZUH_INDEXER_PASSWORD=
WAZUH_DASHBOARD_PASSWORD=

# ── ⚙🐳 Greenbone / OpenVAS ───────────────────────────────────
GREENBONE_HOST=wazuh.manager        # hostname inside scanner-net
GREENBONE_USERNAME=admin
GREENBONE_PASSWORD=
# ── 🐳 oss-stack/greenbone/docker-compose.yml only
GREENBONE_PG_PASSWORD=

# ── ⚙ OWASP ZAP ──────────────────────────────────────────────
ZAP_URL=http://zap:8080
ZAP_API_KEY=                        # openssl rand -hex 16

# ── ⚙ DefectDojo (Dedup aggregator) ──────────────────────────
DEFECTDOJO_URL=http://defectdojo:8080
DEFECTDOJO_API_KEY=
DEFECTDOJO_DATABASE_URL=postgresql://securesync:PASSWORD@postgres:5432/defectdojo
DEFECTDOJO_SECRET_KEY=              # openssl rand -hex 32
DEFECTDOJO_AES_KEY=                 # exactly 32 chars

# ── ⚙ External APIs (CVE / breach data) ──────────────────────
EPSS_API_URL=https://api.first.org/data/v1
NVD_API_KEY=                        # register at nvd.nist.gov (optional but rate-limit boost)
HIBP_API_KEY=                       # haveibeenpwned.com/API/Key (paid)

# ── ⚙ NinjaOne RMM (Phase 4.1) ───────────────────────────────
NINJAONE_CLIENT_ID=
NINJAONE_CLIENT_SECRET=
NINJAONE_API_URL=https://app.ninjarmm.com

# ── 🐳 Let's Encrypt (infra/nginx/issue_cert.sh) ─────────────
LETSENCRYPT_EMAIL=ops@nexo-ai.ch    # used for renewal notices

# ── ⚙ SMTP (invitation emails, report delivery — Phase 4+) ───
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@nexo-ai.ch
SMTP_FROM_NAME=SecureSync by NEXO AI

# ── ⚙⚡ Sentry (error + APM) ──────────────────────────────────
SENTRY_DSN_BACKEND=                 # leave empty to disable
SENTRY_DSN_FRONTEND=                # Next.js reads this directly
# GIT_SHA is injected at Docker build time (see deploy.yml); no need to set locally.

# ── ⚙ Seed script (scripts/seed.py) ──────────────────────────
# Optional overrides for initial MSP + platform-admin creation.
SEED_ADMIN_EMAIL=admin@nexo-ai.ch
SEED_ADMIN_PASSWORD=                # leave empty → random + printed to stdout
SEED_MSP_NAME=NEXO AI
SEED_MSP_SLUG=nexo-ai
